        "${workspaceFolder}/api/include",
        "${workspaceFolder}/sqlite/include",
        "${workspaceFolder}/sqlite/src",
        "${workspaceFolder}/python/bindings"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/core/include",
          "${workspaceFolder}/core/src",
          "${workspaceFolder}/api/include",
          "${workspaceFolder}/sqlite/include",
          "${workspaceFolder}/sqlite/src",
          "${workspaceFolder}/python/bindings"
